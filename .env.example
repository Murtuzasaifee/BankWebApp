# ============================================================================
# AI Agent Platform Credentials
# ============================================================================
PLATFORM_BASE_URL=https://api.intellectseecstag.com/magicplatform/v1
AUTH_BASE_URL=https://api.intellectseecstag.com/accesstoken
TENANT=your_tenant
API_KEY=your_api_key
WORKSPACE_ID=your_workspace_id
PLATFORM_USERNAME=your_username
PLATFORM_PASSWORD=your_password

# ============================================================================
# Application Branding
# ============================================================================
APP_NAME=Good Bank

# ============================================================================
# Agent Configuration
# ============================================================================
# Asset IDs (ChatNow, IntelliChat, subcategories) are stored in the database
# app_config table and managed via the Admin UI → Asset Configuration.
# Run: python scripts/migrate_add_app_config.py  to initialise the table.
AGENT_NAME=
CONVERSATION_NAME=
QUERY_TIMEOUT=60

# ============================================================================
# Application Configuration
# ============================================================================
ENVIRONMENT=local
SECRET_KEY=your_secret_key_here
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
DEBUG_MODE=true
LOG_LEVEL=INFO
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
